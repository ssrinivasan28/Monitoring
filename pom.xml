            <phase>package</phase>
            <goals><goal>shade</goal></goals>
            <configuration>
              <finalName>IBMProfieDisable</finalName>
              <transformers>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                  <mainClass>com.islandpacific.monitoring.userprofilechecker.MainUserProfileChecker</mainClass>
                </transformer>
              </transformers>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
