        </executions>
      </plugin>

      <!-- Move shaded JARs to /monitors -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-antrun-plugin</artifactId>
        <version>3.1.0</version>
        <executions>
          <execution>
            <id>move-shaded-jars</id>
            <phase>package</phase>
            <configuration>
              <target>
                <mkdir dir="${project.build.directory}/monitors"/>
                <move todir="${project.build.directory}/monitors">
                  <fileset dir="${project.build.directory}" includes="IBM*.jar,ServerUpTimeMonitor.jar,WinFS*.jar,LogKeywordMonitor.jar,WinMonitor.jar"/>
                </move>
              </target>
            </configuration>
            <goals>
              <goal>run</goal>
            </goals>
          </execution>
        </executions>
      </plugin>

    </plugins>
  </build>
</project>
