                  </excludes>
                </filter>
              </filters>
            </configuration>
          </execution>

          <!-- Windows File System Error Monitor -->
          <execution>
            <id>shade-winfs-error-monitor</id>
            <phase>package</phase>
            <goals><goal>shade</goal></goals>
            <configuration>
